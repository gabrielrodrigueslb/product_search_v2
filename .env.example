PORT=3100
BANCO_UNICO_API_BASE_URL=https://unicocontato.tech/banco-unico
BANCO_UNICO_TIMEOUT_MS=60000
BANCO_UNICO_SEARCH_LIMIT=20
VETOR_API_BASE_URL=https://integracao.zetti.dev
VETOR_MAX_EANS_PER_REQUEST=10
VETOR_MAX_PARALLEL_REQUESTS=4

OMNICHANNEL_ATTENDANCES_URL=https://sua-api-omnichannel.com/attendances
OMNICHANNEL_MESSAGES_URL_TEMPLATE=https://sua-api-omnichannel.com/attendances/{id}/messages
OMNICHANNEL_API_TOKEN=
OMNICHANNEL_AUTH_HEADER=Authorization
OMNICHANNEL_AUTH_SCHEME=Bearer
OMNICHANNEL_ITEMS_PATH=data.items
OMNICHANNEL_MESSAGES_ITEMS_PATH=data.items
OMNICHANNEL_PAGE_PARAM=page
OMNICHANNEL_PAGE_SIZE_PARAM=limit
OMNICHANNEL_PAGE_SIZE=50
OMNICHANNEL_MAX_PAGES=2
OMNICHANNEL_TIMEOUT_MS=30000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=45000

PRODUCT_SEARCH_API_BASE_URL=http://localhost:3100
PRODUCT_SEARCH_API_PATH=/providers/vetor/products/search/semantic
PRODUCT_SEARCH_VETOR_TOKEN=
PRODUCT_SEARCH_CDFILIAL=1
PRODUCT_SEARCH_TIMEOUT_MS=30000

EVAL_OUTPUT_DIR=artifacts/omnichannel-eval
EVAL_LIMIT_ATTENDANCES=50
EVAL_MAX_PARALLEL_SEARCHES=3
EVAL_INCLUDE_TRANSCRIPT=false
